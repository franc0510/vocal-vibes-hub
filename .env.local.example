# Supabase Configuration
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_PUBLIC_KEY

# Notes:
# 1. Get VITE_SUPABASE_URL from: Supabase Dashboard → Settings → API → Project URL
# 2. Get VITE_SUPABASE_PUBLISHABLE_KEY from: Supabase Dashboard → Settings → API → anon (public)
# 3. NEVER commit this file or expose secret keys in frontend
# 4. This file is in .gitignore already
